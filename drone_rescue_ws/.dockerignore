# Docker ignore file for drone_rescue_ws

# Build artifacts (will be rebuilt in container)
build/
install/
log/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore

# Docker files (don't need to copy these into the image)
Dockerfile
docker-compose.yml
.dockerignore

# Documentation (optional - can include if needed)
docs/
*.md
!src/**/*.md

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# Logs
*.log
log/

# Temporary files
tmp/
temp/
*.tmp

# OS files
.DS_Store
Thumbs.db

# ROS specific
*.bag
*.db3
